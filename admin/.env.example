# Team Guerilla Admin Panel
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin

PORT=3000
JWT_SECRET=buraya-guclu-bir-secret-yazin
CORS_ORIGIN=*
FRONTEND_DIR=../frontend

# E-posta bildirim ayarları (isteğe bağlı)
# Bu ayarlar yapılırsa iletişim formu mesajları e-posta olarak da gönderilir
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@teamguerilla.com
CONTACT_EMAIL=info@teamguerilla.com
