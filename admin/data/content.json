  "about.value0.title.tr": {
    "value": "Sahada Güçlüyüz",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value0.title.en": {
    "value": "Strong in the Field",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value0.desc.tr": {
    "value": "Masabaşı stratejiler değil, sahada sonuç üreten ekipler. 81 ilde operasyon kapasitemizle her noktaya ulaşıyoruz.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value0.desc.en": {
    "value": "Not desk strategies, but teams that deliver results in the field. We reach every point with our operational capacity across 81 provinces.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value1.title.tr": {
    "value": "Veriye Dayalı Çalışıyoruz",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value1.title.en": {
    "value": "Data-Driven",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value1.desc.tr": {
    "value": "Her operasyonu raporluyor, her kampanyayı ölçüyor, her sonucu analiz ediyoruz. Müşterilerimize his değil, veri sunuyoruz.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value1.desc.en": {
    "value": "We report every operation, measure every campaign, analyze every result. We offer our clients data, not feelings.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value2.title.tr": {
    "value": "Esnek ve Hızlıyız",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value2.title.en": {
    "value": "Flexible and Fast",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value2.desc.tr": {
    "value": "Her marka farklı, her proje kendine özgü. Standart paketler yerine ihtiyaca özel çözümler üretiyoruz.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value2.desc.en": {
    "value": "Every brand is different, every project is unique. We create custom solutions instead of standard packages.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value3.title.tr": {
    "value": "İnsan Odaklıyız",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value3.title.en": {
    "value": "People-Focused",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value3.desc.tr": {
    "value": "Ekibimize yatırım yapıyoruz çünkü sahada farkı insanlar yaratır. Sürekli eğitim, düzgün çalışma koşulları ve motivasyon.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  },
  "about.value3.desc.en": {
    "value": "We invest in our team because people make the difference in the field. Continuous training, proper working conditions and motivation.",
    "updatedAt": "2026-03-06T14:45:42.046Z"
  }
}